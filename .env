VITE_BASE_URL=http://localhost:5005/api

# Login ছাড়া ভিতরের রাউট + role gate (TEACHER /admin এ যাবে না):
VITE_DEV_MOCK_AUTH=true
# admin | SUPER_ADMIN | TEACHER — সুপার অ্যাডমিন UI একই /admin (বা /super-admin → redirect)
VITE_DEV_MOCK_ROLE=admin

# Login/register ডান পাশে ছবি (public/ ফোল্ডারে রেখে path দিন), যেমন: /campus.jpg
# VITE_AUTH_PANEL_IMAGE=/campus.jpg
